EXPO_PUBLIC_API_BASE_URL=https://cbk-4dmf.onrender.com

# Replace these with your real AdMob ad unit IDs before production build.
# Keep test IDs in development builds only.
EXPO_PUBLIC_ADMOB_BANNER_ID=ca-app-pub-7501738870401219/2488455783
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID=ca-app-pub-7501738870401219/3436360931

# Optional: force test ads on release APKs used for QA (set to true/false)
EXPO_PUBLIC_FORCE_TEST_ADS=false

# Optional: comma-separated test device IDs for AdMob release debugging
# EXPO_PUBLIC_ADMOB_TEST_DEVICE_IDS=ABCDEF012345,ZYXW987654

# Optional: override Play Store package/version used by in-app update prompt
EXPO_PUBLIC_PLAY_STORE_PACKAGE=com.krishnendu28.cbkapp
# EXPO_PUBLIC_PLAY_STORE_LATEST_VERSION=1.0.1

{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "production": {
      "env": {
        "EXPO_NO_TELEMETRY": "1"
      }
    },
    "apk-debug": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EXPO_NO_TELEMETRY": "1"
      }
    },
    "apk-release": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_NO_TELEMETRY": "1"
      }
    },
    "apk": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_NO_TELEMETRY": "1"
      }
    },
    "ios": {
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_NO_TELEMETRY": "1"
      }
    }
  }
}
